{
  "root": true,
  "extends": ["react-app", "react-app/jest", "prettier"],
  "plugins": ["prettier"],
  "env": {
    "browser": true,
    "es2021": true
  },
  "parserOptions": {
    "ecmaVersion": 2021,
    "sourceType": "module"
  },
  "rules": {
    "prettier/prettier": "warn",
    "react/react-in-jsx-scope": "off"
  }
}